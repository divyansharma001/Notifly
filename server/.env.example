# Copy to .env and fill in. This file IS committed; .env is not.
DATABASE_URL=postgres://notify:notify@localhost:5432/notify
REDIS_HOST=localhost
REDIS_PORT=6379
PORT=4000

# Email provider (Phase 6). Blank RESEND_API_KEY => email runs as a console stub.
# Set it to a Resend API key to send for real. EMAIL_FROM defaults to Resend's
# sandbox sender, which only delivers to your own Resend account email.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Rate limiting (Phase 7) — cap per user+channel within a rolling window.
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_SEC=3600

# Dashboard service credentials (Phase 7 auth). The seed creates a "dashboard"
# service with these; the Vite proxy sends them so the browser holds no secret.
DASH_APP_KEY=nfy_key_dashboard
DASH_APP_SECRET=nfy_secret_dashboard_dev
